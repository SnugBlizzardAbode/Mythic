use package::token

enum LexerErr {
    FileErr(os::FileErr)
}

fn scan(file: Path) LexerErr![Token] {
    let src = os::read_file(file).catch(|e|LexerErr.FileErr(e))
    let token = Tokenizer{src}.scan()?
    token
}

class Tokenizer {
    struct { 
        src: String
        token: ?[Token] = none
        line: i64 = 0
        char: i64 = 0
    }

    fn scan(var self) LexerErr![Token] {
        
    }
}
    
    

