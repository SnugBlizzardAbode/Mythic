enum Node{
    PackageDef { item: [] }
    ImportDef { item: [Path] }
    ModDef(ModeNode)
    StructDef(StructNode)
    EnumDef(EnumNode)
    ClassDef(ClassNode)
    ExtendDef(ExtendNode)
    VarDef(VarDefNode)
    FnDef(FnNode)
}

struct PackageNode {

}

struct ArgDef {
    mutable: bool
    name: String
}

struct FnDef {
    name: String
    public: bool
    arg: ?[ArgNode] = None
}

