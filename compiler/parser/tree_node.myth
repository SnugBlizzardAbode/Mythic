enum Node{
    PackageDef(PackageNode)
    ImportDef(ImportNode)
    ModDef(ModeNode)
    StructDef(StructNode)
    EnumDef(EnumNode)
    ClassDef(ClassNode)
    ExtendDef(ExtendNode)
    VarDef(VarDefNode)
    FnDef(FnNode)
}

struct ArgDef {
    mutable: bool
    name: String
}

struct FnDef {
    name: String
    public: bool
    arg: ?[ArgNode] = None
}